# Instalado en /etc/sudoers.d/panel por link-units.sh. El usuario `panel` solo
# puede: arrancar/parar/consultar units de sesión, y correr los helpers de
# render/provisioning (que corren como root para leer panel.env y chown a
# `agents`). Nada más con sudo.
panel ALL=(root) NOPASSWD: /usr/bin/systemctl start claude-session@*, /usr/bin/systemctl stop claude-session@*, /usr/bin/systemctl status claude-session@*
panel ALL=(root) NOPASSWD: /opt/panel/deploy/panel-render.sh
panel ALL=(root) NOPASSWD: /opt/panel/deploy/panel-provision.sh [a-z0-9-]* /srv/projects/*
panel ALL=(root) NOPASSWD: /opt/panel/deploy/panel-clone.sh /srv/projects/*
# SP4: hard-delete del dir de un proyecto. La validación de path está DENTRO
# del script (case /srv/projects/* + no `..`), pero sudoers lo acota al
# whitelist como defensa adicional.
panel ALL=(root) NOPASSWD: /opt/panel/deploy/panel-purge.sh /srv/projects/*

# SP8: chown a agents:agents de archivos materializados por el render. El
# script valida que el path esté bajo /srv/projects/.
panel ALL=(root) NOPASSWD: /opt/panel/deploy/panel-chown-agents.sh /srv/projects/*

# SP15: vista de contenedores Docker. Solo `list` y `stop <id>` — el script NO
# expone rm/down/-v, y rechaza parar contenedores de la infra del panel
# (panel-infra), que además se ocultan de la vista.
panel ALL=(root) NOPASSWD: /opt/panel/deploy/panel-docker.sh list
panel ALL=(root) NOPASSWD: /opt/panel/deploy/panel-docker.sh stop [a-zA-Z0-9]*
